# SynCVE Secrets (only API keys here, all other config in config/settings.yml)
# Copy to backend.env: copy backend.env.example backend.env

# Supabase — https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
