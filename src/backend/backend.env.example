# ============================================================================
# SynCVE Backend Configuration Template
# Copy this file to backend.env and fill in your values:
#   copy backend.env.example backend.env
# ============================================================================

# ============================================================================
# Server Configuration
# ============================================================================

# Backend Host (0.0.0.0 = listen on all interfaces)
BACKEND_HOST=0.0.0.0

# Backend Port
BACKEND_PORT=5005

# Debug Mode (false for production, true for development)
DEBUG=false

# ============================================================================
# GPU Configuration
# ============================================================================

# CUDA Device Selection (0 = GPU 0, -1 = CPU only)
CUDA_VISIBLE_DEVICES=0

# TensorFlow Logging Level (0=all, 1=info, 2=warnings, 3=errors)
TF_CPP_MIN_LOG_LEVEL=2

# GPU Memory Growth (true = allocate dynamically, recommended)
TF_FORCE_GPU_ALLOW_GROWTH=true

# ============================================================================
# Memory Optimization
# ============================================================================

# GPU Memory Fraction (0.0-1.0, e.g. 0.8 = use up to 80% of VRAM)
TF_GPU_MEMORY_FRACTION=0.8

# GPU Thread Mode
TF_GPU_THREAD_MODE=gpu_private
TF_GPU_THREAD_PER_DEVICE=2

# ============================================================================
# Performance Tuning
# ============================================================================

# Leave empty for auto-detection of CUDA compute capability
CUDA_COMPUTE_CAPABILITY=

# Enable oneDNN optimizations (1 = enabled)
TF_ENABLE_ONEDNN_OPTS=1

# CPU thread count (match your CPU core count)
OMP_NUM_THREADS=8

# ============================================================================
# DeepFace Configuration (DeepFace 0.0.99+)
# ============================================================================

# Face Detection Backend
# Available: opencv, ssd, dlib, mtcnn, fastmtcnn, retinaface, mediapipe,
#   yolov8n/m/l, yolov11n/s/m/l, yolov12n/s/m/l, yunet, centerface
# retinaface = most accurate (GPU), opencv = fastest (CPU)
DEEPFACE_DETECTOR_BACKEND=retinaface

# Ensemble Detectors (comma-separated, used when ENABLE_EMOTION_ENSEMBLE=1)
EMOTION_ENSEMBLE_DETECTORS=retinaface,mtcnn,centerface

# Face Recognition Model (VGG-Face, Facenet, Facenet512, ArcFace, OpenFace, DeepID, SFace)
DEEPFACE_MODEL_NAME=Facenet

# Distance Metric (cosine, euclidean, euclidean_l2)
DEEPFACE_DISTANCE_METRIC=cosine

# ============================================================================
# Batch Processing
# ============================================================================

# Batch size for image processing (lower = less VRAM, higher = faster)
BATCH_SIZE=32

# ============================================================================
# Monitoring & Logging
# ============================================================================

# Enable GPU usage monitoring (true/false)
GPU_MONITORING=true

# Log memory usage per request (true/false)
LOG_GPU_MEMORY=true

# ============================================================================
# Advanced Optimization
# ============================================================================

# XLA Compilation (experimental, may speed up inference)
TF_XLA_FLAGS=--tf_xla_enable_xla_devices

# Deterministic operations (true = reproducible but slower)
TF_DETERMINISTIC_OPS=false

# ============================================================================
# Supabase (Database) - REQUIRED for session tracking
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# ============================================================================

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ============================================================================
# Google Gemini (LLM Report Generation) - REQUIRED for AI reports
# Get your key from: https://aistudio.google.com/apikey
# SDK: google-genai (unified SDK, replaces deprecated google-generativeai)
# Docs: https://ai.google.dev/gemini-api/docs/models
#
# Text models:  gemini-2.5-flash (stable), gemini-2.5-pro (most capable),
#               gemini-3.1-pro-preview (cutting-edge preview)
# Image models: gemini-2.5-flash-image (stable),
#               gemini-3.1-flash-image-preview (latest preview),
#               gemini-3-pro-image-preview (pro-tier preview)
# ============================================================================

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_IMAGE_MODEL_NAME=gemini-2.5-flash-image
GEMINI_IMAGE_MODEL_FALLBACK=gemini-3.1-flash-image-preview,gemini-3-pro-image-preview

# Retry/timeout settings
GEMINI_REQUEST_TIMEOUT=120
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_DELAY=1.0
