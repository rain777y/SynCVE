# SynCVE Frontend Configuration
# Copy to .env: copy .env.example .env

# Backend API endpoint
REACT_APP_SERVICE_ENDPOINT=http://localhost:5005

# Supabase auth — https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Detection settings
REACT_APP_DETECTOR_BACKEND=retinaface
REACT_APP_ANTI_SPOOFING=1
REACT_APP_DETECTION_INTERVAL=2000
