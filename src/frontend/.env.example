# ============================================================================
# SynCVE Frontend Configuration Template
# Copy this file to .env and fill in your values:
#   copy .env.example .env
# ============================================================================

# --- Backend API ----------------------------------------------------------
# URL where the Flask backend is running
REACT_APP_SERVICE_ENDPOINT=http://localhost:5005

# --- Supabase (required for auth & session history) -----------------------
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Face Recognition Model -----------------------------------------------
# Options: VGG-Face, Facenet, Facenet512, OpenFace, DeepFace, DeepID, ArcFace, Dlib, SFace, GhostFaceNet
REACT_APP_FACE_RECOGNITION_MODEL=Facenet

# --- Face Detector Backend ------------------------------------------------
# Options: opencv, ssd, dlib, mtcnn, retinaface, mediapipe, yolov8, yunet, fastmtcnn
# retinaface = most accurate (GPU recommended), opencv = fastest (CPU friendly)
REACT_APP_DETECTOR_BACKEND=opencv

# --- Distance Metric ------------------------------------------------------
# Options: cosine, euclidean, euclidean_l2
REACT_APP_DISTANCE_METRIC=cosine

# --- Anti-Spoofing --------------------------------------------------------
# 0 = disabled, 1 = enabled (requires PyTorch CUDA for best performance)
REACT_APP_ANTI_SPOOFING=0

# --- Continuous Detection Settings ----------------------------------------
# Detection interval in milliseconds (500, 1000, 1500, 2000, 3000)
REACT_APP_DETECTION_INTERVAL=1500

# Auto-start detection when the page loads (true/false)
REACT_APP_AUTO_START_DETECTION=false

# --- Facial Database (optional) -------------------------------------------
# Register known faces for verification. Format:
#   REACT_APP_USER_<NAME>=<base64_image_or_url>
# Examples:
#   REACT_APP_USER_John=https://example.com/john.jpg
#   REACT_APP_USER_Jane=data:image/jpeg;base64,/9j/4AAQSkZJRg...
